# Public Supabase env vars — safe to ship in the browser bundle.
# Protected by RLS, not by key secrecy.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only secrets. NEVER prefix with VITE_/NEXT_PUBLIC_/NUXT_PUBLIC_/PUBLIC_.
# Used by server routes, edge functions, and scripts/seed-users.sh.
# SUPABASE_SERVICE_ROLE_KEY=
